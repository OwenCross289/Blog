---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />

<!--
	Theme boot: resolves System / Light / Dark before first paint so there is no
	flash of the wrong theme. Exposes window.__theme so the header's switch can
	reuse the same resolve/apply/persist logic instead of duplicating it.
-->
<script is:inline>
	(function () {
		var STORAGE_KEY = 'oc-theme';
		var root = document.documentElement;
		var media = window.matchMedia('(prefers-color-scheme: dark)');

		function systemTheme() {
			return media.matches ? 'dark' : 'light';
		}

		function resolve(preference) {
			return preference === 'light' || preference === 'dark' ? preference : systemTheme();
		}

		function apply(preference) {
			var resolved = resolve(preference);
			root.setAttribute('data-theme-preference', preference);
			root.setAttribute('data-theme', resolved);
			return resolved;
		}

		function get() {
			var stored = null;
			try {
				stored = localStorage.getItem(STORAGE_KEY);
			} catch (error) {
				stored = null;
			}
			return stored === 'light' || stored === 'dark' || stored === 'system' ? stored : 'system';
		}

		function set(preference) {
			try {
				localStorage.setItem(STORAGE_KEY, preference);
			} catch (error) {
				/* storage unavailable; theme still applies for this page view */
			}
			return apply(preference);
		}

		window.__theme = { apply: apply, set: set, get: get, systemTheme: systemTheme };

		apply(get());

		media.addEventListener('change', function () {
			if (get() === 'system') apply('system');
		});
	})();
</script>
<meta name="color-scheme" content="light dark" />
<meta name="theme-color" media="(prefers-color-scheme: light)" content="#E9EBEA" />
<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#14161A" />

<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />
<Font cssVariable="--font-display" preload />
<Font cssVariable="--font-mono" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
