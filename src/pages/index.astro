---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Owen Cross</h1>
			<p>
				Senior Software Engineer specialising in .NET, TypeScript and Azure.
			</p>
			<p>
				This site is where I share what I am working on, write about software, and keep a few things
				about me in one place.
			</p>
			<p>
				You can find me on <a href="https://github.com/OwenCross289">GitHub</a>, <a href="https://www.linkedin.com/in/owenphilipcross/">LinkedIn</a>, and <a href="https://x.com/OwenCrossssss">X</a>.
			</p>
			<p>
				If you are here for the blog, head over to the latest posts or have a look around.
			</p>
		</main>
		<Footer />
	</body>
</html>
